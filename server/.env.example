# Server
PORT=4000
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/ripple

# JWT
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d

# AES-256 token encryption (32 bytes hex)
ENCRYPTION_KEY=change_me_to_64_hex_chars_representing_32_bytes

# Tradovate OAuth vendor credentials
TRADOVATE_CLIENT_ID=your_vendor_client_id
TRADOVATE_CLIENT_SECRET=your_vendor_client_secret
TRADOVATE_REDIRECT_URI=http://localhost:4000/api/oauth/tradovate/callback

# Environment: demo | live
TRADOVATE_ENV=demo

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Frontend URL (for CORS + OAuth redirects)
FRONTEND_URL=http://localhost:3000
